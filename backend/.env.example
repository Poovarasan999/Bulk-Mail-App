PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/bulk-mail-app

# Gmail: MAIL_PASS = Google App Password (16 chars), not your normal password.
MAIL_SERVICE=gmail
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=your_email@gmail.com

# Gmail uses 587 + IPv4-friendly DNS (fixes ENETUNREACH to IPv6 on some networks).
# Custom SMTP host: set SMTP_LOOKUP_IPV4=true to force IPv4 lookup.
# GMAIL_SMTP_PORT=465

# Or any provider:
# SMTP_URL=smtps://user:pass@smtp.sendgrid.net:465